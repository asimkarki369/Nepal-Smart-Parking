{
  "expo": {
    "name": "Nepal Smart Parking",
    "slug": "nsp-driver",
    "scheme": "nsp-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A3A6B"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A3A6B"
      },
      "package": "com.nsp.driver",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "POST_NOTIFICATIONS"
      ]
    },
    "experiments": {
      "baseUrl": "/Nepal-Smart-Parking"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Nepal Smart Parking needs your location to find nearby parking zones."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1A3A6B"
        }
      ],
      [
        "react-native-maps",
        {
          "googleMapsApiKey": "AIzaSyDTaGLkW5rwpvKOvby9AqLZGTnlwY-jyWk"
        }
      ],
      "expo-sharing",
      "expo-local-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "Nepal Smart Parking needs access to your photos to set a profile picture.",
          "cameraPermission": "Nepal Smart Parking needs camera access to take a profile photo."
        }
      ]
    ]
  }
}
