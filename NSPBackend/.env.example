# Database (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgresql://user:password@host:5432/nsp_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# SMS OTP (Sparrow SMS - Nepal)
SPARROW_SMS_TOKEN=your_sparrow_sms_token
SPARROW_SMS_FROM=NSP

# Server
PORT=3000
NODE_ENV=development

# OTP settings
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6

# In dev mode, OTP is always this value (skip real SMS)
DEV_OTP=123456
